{
	"name": "@neokai/daemon",
	"version": "0.9.0",
	"type": "module",
	"license": "Apache-2.0",
	"main": "main.ts",
	"exports": {
		".": "./main.ts",
		"./app": "./src/app.ts",
		"./config": "./src/config.ts",
		"./routes/setup-websocket": "./src/routes/setup-websocket.ts",
		"./sdk-cli-resolver": "./src/lib/agent/sdk-cli-resolver.ts"
	},
	"scripts": {
		"dev": "bun run --watch main.ts",
		"start": "NODE_ENV=production bun run main.ts",
		"test": "bun run test:unit && bun run test:online",
		"test:unit": "bun test --preload=./tests/unit/setup.ts ./tests/unit",
		"test:unit:all": "cd ../.. && ./scripts/test-daemon.sh",
		"test:unit:coverage": "cd ../.. && ./scripts/test-daemon.sh --coverage",
		"test:unit:rerun": "cd ../.. && ./scripts/test-daemon.sh --rerun",
		"test:online": "bun test --coverage --coverage-reporter=text ./tests/online"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "0.2.112",
		"@github/copilot-sdk": "0.2.2",
		"@neokai/shared": "workspace:*",
		"@openai/codex": "0.121.0",
		"croner": "10.0.1",
		"simple-git": "3.36.0",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@types/bun": "1.3.12"
	}
}
