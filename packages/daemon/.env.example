# NeoKai Environment Configuration
#
# This file is automatically loaded by Bun at startup.
# Copy to .env and customize for your environment.
# Bun loads files in order: .env → .env.local (later overrides earlier)
#
# No dotenv package needed - Bun has built-in .env support!

# Server Configuration
PORT=9283
HOST=0.0.0.0

# Database
# DB_PATH=./data/daemon.db

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Authentication
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# Kai auto-discovers credentials from Claude Code. If you've
# already logged in with `claude login`, no configuration needed.
#
# Credential discovery order:
#   1. Environment variables (this file or shell exports)
#   2. ~/.claude/.credentials.json (Claude Code login)
#   3. macOS Keychain (Claude Code login)
#   4. ~/.claude/settings.json env block (third-party providers)
#
# To set credentials manually, use ONE of these:

# Option 1: Anthropic API Key
# ANTHROPIC_API_KEY=sk-ant-...

# Option 2: Claude Code OAuth Token (from `claude setup-token`)
# CLAUDE_CODE_OAUTH_TOKEN=...

# Option 3: Third-party provider (configure in ~/.claude/settings.json)
# See: https://docs.anthropic.com/en/docs/claude-code/settings

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# GitHub Copilot provider (anthropic-copilot)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# GitHub token used by the Copilot provider (optional — the provider can
# also discover a token from ~/.copilot/apps.json or GITHUB_TOKEN).
# COPILOT_GITHUB_TOKEN=ghp_...
#
# Linux local-dev note: the Copilot CLI subprocess requires node:sqlite
# (Node.js >= 22.5.0). On Linux, Bun does not supply this module, so the
# system `node` on PATH must be >= 22.5 (Node.js 22 LTS or Node.js 24
# recommended). macOS users are unaffected — Bun on macOS supports node:sqlite
# and is automatically used as the subprocess runtime.

# Model Configuration
DEFAULT_MODEL=default
MAX_TOKENS=8192
TEMPERATURE=1.0
MAX_SESSIONS=10

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SDK Startup Tuning
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# How long (ms) to wait for the SDK subprocess to emit its first message
# before declaring a startup timeout. Increase on slow machines or when
# running many concurrent sessions.
# Default: 15000
# NEOKAI_SDK_STARTUP_TIMEOUT_MS=15000
#
# Base delay (ms) before the first auto-recovery attempt after a startup
# timeout. Each subsequent attempt doubles this (exponential backoff).
# Example: 3000 → attempt 1 waits 3s, attempt 2 waits 6s.
# Default: 3000
# NEOKAI_SDK_STARTUP_RECOVERY_DELAY_MS=3000
#
# Maximum number of auto-recovery attempts before surfacing the error to
# the user. Set to 0 to disable auto-recovery entirely.
# Default: 2
# NEOKAI_SDK_STARTUP_MAX_RETRIES=2

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Job Queue Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# Maximum number of jobs that can run concurrently across all queues.
# Increase if you have many background tasks (GitHub polling, room ticks,
# session title generation) that need to run in parallel.
# Default: 5
# NEOKAI_JOB_QUEUE_MAX_CONCURRENT=5

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Test Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# These options control how online tests mock AI API calls.

# Dev Proxy (realistic HTTP mocking, requires dev-proxy installed)
# NEOKAI_USE_DEV_PROXY=1
# When using Dev Proxy, also set:
# HTTPS_PROXY=http://127.0.0.1:8000
# HTTP_PROXY=http://127.0.0.1:8000
# NODE_USE_ENV_PROXY=1
# NODE_EXTRA_CA_CERTS=~/.proxy/rootCA.pem
