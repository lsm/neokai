{
	"$schema": "https://raw.githubusercontent.com/dotnet/dev-proxy/main/schemas/v2.2.0/mockresponseplugin.mocksfile.schema.json",
	"mocks": [
		{
			"comment": "Space agent - supervised mode: escalate to human (matches on autonomy level in injected message)",
			"request": {
				"url": "http://127.0.0.1:8000/v1/messages?beta=true",
				"method": "POST",
				"body": {
					"matcher": ".JsonContains",
					"key": "messages",
					"value": "probe_supervised_escalation"
				}
			},
			"response": {
				"statusCode": 200,
				"headers": [
					{ "name": "content-type", "value": "application/json" },
					{ "name": "x-mocked-by", "value": "Dev Proxy - mocks-space-agent.json (supervised)" }
				],
				"body": {
					"id": "msg_space_supervised_001",
					"type": "message",
					"role": "assistant",
					"content": [
						{
							"type": "text",
							"text": "[MOCKED SUPERVISED] Task task-needs-attention-123 requires human attention. I am in supervised mode and cannot act autonomously. I need your approval before retrying or cancelling this task. The task failed due to: agent returned an error. What would you like me to do?"
						}
					],
					"model": "claude-haiku-20250307",
					"stop_reason": "end_turn",
					"stop_sequence": null,
					"usage": {
						"input_tokens": 200,
						"output_tokens": 60,
						"cache_creation_input_tokens": 0,
						"cache_read_input_tokens": 0,
						"service_tier": "standard"
					}
				}
			}
		},
		{
			"comment": "Space agent - semi_autonomous: calls get_task_detail to assess the situation (stop_reason end_turn — no follow-up needed, test verifies tool_use block in SDK messages)",
			"request": {
				"url": "http://127.0.0.1:8000/v1/messages?beta=true",
				"method": "POST",
				"body": {
					"matcher": ".JsonContains",
					"key": "messages",
					"value": "probe_semi_autonomous_get_detail"
				}
			},
			"response": {
				"statusCode": 200,
				"headers": [
					{ "name": "content-type", "value": "application/json" },
					{
						"name": "x-mocked-by",
						"value": "Dev Proxy - mocks-space-agent.json (semi_autonomous get_task_detail)"
					}
				],
				"body": {
					"id": "msg_space_semi_detail_001",
					"type": "message",
					"role": "assistant",
					"content": [
						{
							"type": "text",
							"text": "A task needs attention. Let me get the details to assess the situation."
						},
						{
							"type": "tool_use",
							"id": "toolu_get_detail_001",
							"name": "get_task_detail",
							"input": {
								"task_id": "PLACEHOLDER_TASK_ID"
							}
						}
					],
					"model": "claude-haiku-20250307",
					"stop_reason": "end_turn",
					"stop_sequence": null,
					"usage": {
						"input_tokens": 200,
						"output_tokens": 80,
						"cache_creation_input_tokens": 0,
						"cache_read_input_tokens": 0,
						"service_tier": "standard"
					}
				}
			}
		},
		{
			"comment": "Space agent - semi_autonomous: calls retry_task autonomously (stop_reason end_turn — no follow-up needed, test verifies tool_use block in SDK messages)",
			"request": {
				"url": "http://127.0.0.1:8000/v1/messages?beta=true",
				"method": "POST",
				"body": {
					"matcher": ".JsonContains",
					"key": "messages",
					"value": "probe_semi_autonomous_retry"
				}
			},
			"response": {
				"statusCode": 200,
				"headers": [
					{ "name": "content-type", "value": "application/json" },
					{
						"name": "x-mocked-by",
						"value": "Dev Proxy - mocks-space-agent.json (semi_autonomous retry_task)"
					}
				],
				"body": {
					"id": "msg_space_semi_retry_001",
					"type": "message",
					"role": "assistant",
					"content": [
						{
							"type": "text",
							"text": "I am in semi-autonomous mode. I will retry this failed task autonomously."
						},
						{
							"type": "tool_use",
							"id": "toolu_retry_001",
							"name": "retry_task",
							"input": {
								"task_id": "PLACEHOLDER_TASK_ID"
							}
						}
					],
					"model": "claude-haiku-20250307",
					"stop_reason": "end_turn",
					"stop_sequence": null,
					"usage": {
						"input_tokens": 200,
						"output_tokens": 80,
						"cache_creation_input_tokens": 0,
						"cache_read_input_tokens": 0,
						"service_tier": "standard"
					}
				}
			}
		}
	]
}
